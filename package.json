{
        "name": "yandex-next",
        "version": "3.10.3",
        "description": "Web client for Yandex Music with support for themes, addons, Discord Rich Presence (RPC) and OBS widget",
        "main": "dist/index.js",
        "engines": {
                "node": ">=24.0.0",
                "pnpm": ">=9.0.0"
        },
        "packageManager": "pnpm@11.2.2",
        "scripts": {
                "dev:vite": "vite",
                "dev:electron": "electron src/index.js",
                "dev": "concurrently \"pnpm run dev:vite\" \"pnpm run dev:electron\"",
                "build:renderer": "vite build",
                "build:electron": "vite build --config vite.main.config.js",
                "build": "vite build && vite build --config vite.main.config.js",
                "build:win": "vite build && vite build --config vite.main.config.js && cross-env pnpm_config_verify_deps_before_run=false electron-builder --win --publish never",
                "build:linux": "vite build && vite build --config vite.main.config.js && cross-env pnpm_config_verify_deps_before_run=false electron-builder --linux --publish never",
                "build:all": "vite build && vite build --config vite.main.config.js && cross-env pnpm_config_verify_deps_before_run=false electron-builder --win --linux --publish never",
                "start": "electron dist/index.js",
                "format": "prettier --write .",
                "format:check": "prettier --check ."
        },
        "build": {
                "appId": "com.nextmusic.client",
                "productName": "Yandex Next",
                "publish": [
                        {
                                "provider": "github",
                                "owner": "ItsMagisterio",
                                "repo": "YandexNextMusic_client"
                        }
                ],
                "files": [
                        "dist/**/*",
                        "package.json"
                ],
                "directories": {
                        "buildResources": "src/assets",
                        "output": "release"
                },
                "win": {
                        "artifactName": "${name}_${version}_${arch}-Setup.${ext}",
                        "target": [
                                {
                                        "target": "nsis",
                                        "arch": [
                                                "x64"
                                        ]
                                }
                        ],
                        "icon": "src/assets/nm-icons/icon-256.png",
                        "executableName": "Yandex Next"
                },
                "linux": {
                        "artifactName": "${name}_${version}_${arch}.${ext}",
                        "target": [
                                "AppImage",
                                "deb",
                                "pacman"
                        ],
                        "category": "Audio",
                        "maintainer": "magister1o",
                        "icon": "src/assets/nm-icons/icon-256.png",
                        "executableName": "yandex-next"
                },
                "pacman": {
                        "depends": [
                                "gtk3",
                                "libnotify",
                                "nss",
                                "libxss",
                                "glibc"
                        ],
                        "artifactName": "${name}_${version}_${arch}.pkg.tar.zst"
                }
        },
        "repository": {
                "type": "git",
                "url": "git+https://github.com/ItsMagisterio/YandexNextMusic_client.git"
        },
        "keywords": [],
        "author": "magister1o",
        "license": "MIT",
        "type": "module",
        "pnpm": {
                "onlyBuiltDependencies": [
                        "@parcel/watcher",
                        "electron",
                        "electron-winstaller",
                        "esbuild"
                ]
        },
        "bugs": {
                "url": "https://github.com/ItsMagisterio/YandexNextMusic_client/issues"
        },
        "homepage": "https://github.com/ItsMagisterio/YandexNextMusic_client#readme",
        "devDependencies": {
                "codemirror": "^5.65.18",
                "concurrently": "^9.2.1",
                "cross-env": "^10.1.0",
                "dotenv": "^17.4.2",
                "electron": "^42.2.0",
                "electron-builder": "^26.8.1",
                "esbuild": "^0.28.0",
                "html-minifier-terser": "^7.2.0",
                "lightningcss": "^1.32.0",
                "prettier": "^3.8.3",
                "sass": "^1.100.0",
                "scss": "^0.2.4",
                "terser": "^5.48.0",
                "vite": "^8.0.14",
                "vite-plugin-electron": "^0.29.1"
        },
        "dependencies": {
                "@fontsource/noto-sans": "^5.2.10",
                "@fontsource/nunito": "^5.2.7",
                "@fontsource/science-gothic": "^5.2.1",
                "@fontsource/space-mono": "^5.2.9",
                "@fontsource/syne": "^5.2.7",
                "@xhayper/discord-rpc": "^1.3.4",
                "electron-updater": "^6.8.3",
                "lamejs": "^1.2.1",
                "mdui": "^2.1.4",
                "ws": "^8.21.0"
        }
}
